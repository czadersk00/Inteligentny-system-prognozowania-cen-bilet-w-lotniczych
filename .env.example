# Skopiuj ten plik jako .env (w katalogu glownym projektu) i uzupelnij wartosci.
# Plik .env nie jest commitowany do repozytorium.

# Konto administratora tworzone przy pierwszym starcie backendu (haslo min. 8 znakow)
INITIAL_ADMIN_EMAIL=admin@predykcje.com
INITIAL_ADMIN_PASSWORD=

# Sekret podpisywania JWT — ustaw unikalna wartosc (np. dlugi losowy ciag)
JWT_SECRET=
